FROM fabrizio2210/docker_light-default_container:latest

# Install system dependencies: Python, curl, ca-certificates, gnupg, lsb-release
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    curl ca-certificates gnupg lsb-release \
    chromium \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Docker CLI and buildx plugin from Docker's official apt repo
RUN install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg \
       | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
       https://download.docker.com/linux/debian $(lsb_release -cs) stable" \
       > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y docker-ce-cli docker-buildx-plugin \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Go 1.25.0 (multi-arch: maps uname -m to go arch)
RUN set -e; \
    UNAME=$(uname -m); \
    case "$UNAME" in \
      x86_64)  GOARCH=amd64 ;; \
      aarch64) GOARCH=arm64 ;; \
      armv7l)  GOARCH=armv6l ;; \
      *)       echo "Unsupported arch: $UNAME" && exit 1 ;; \
    esac; \
        curl -fsSL "https://dl.google.com/go/go1.25.0.linux-${GOARCH}.tar.gz" \
       -o /tmp/go.tar.gz \
    && tar -C /usr/local -xzf /tmp/go.tar.gz \
    && rm /tmp/go.tar.gz

ENV PATH="/usr/local/go/bin:$PATH"

# Install Node.js v22 LTS via NodeSource
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Pre-cache Angular frontend npm dependencies
COPY src/js/coverletter-frontend/package.json src/js/coverletter-frontend/package-lock.json \
     /build/frontend/
RUN cd /build/frontend && npm ci

# Create a virtual environment and install required Python libraries
RUN python3 -m venv /opt/venv && \
    /opt/venv/bin/pip install --upgrade pip && \
    /opt/venv/bin/pip install pymongo argparse

# Set the virtual environment as the default Python environment
ENV PATH="/opt/venv/bin:$PATH"

# Set CHROME_BIN: wrapper around chromium that adds --no-sandbox (required when running as root)
RUN printf '#!/bin/sh\nexec /usr/bin/chromium --no-sandbox "$@"\n' \
    > /usr/local/bin/chromium-no-sandbox \
    && chmod +x /usr/local/bin/chromium-no-sandbox
ENV CHROME_BIN=/usr/local/bin/chromium-no-sandbox