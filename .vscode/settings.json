{
    "chat.tools.terminal.autoApprove": {
        "docker compose": true,
        "/^bash tests/e2e\\.sh$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^make generate-proto 2>&1$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^bash scripts/test-gate\\.sh --mode fast 2>&1 \\| tail -20$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^make test-fast$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^make test-full$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^bash scripts\\/test-gate\\.sh/": {
            "approve": true,
            "matchCommandLine": true
        }
    },
    "makefile.configureOnOpen": false
}